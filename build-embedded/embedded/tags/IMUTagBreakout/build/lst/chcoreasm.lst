 175              	/*--------------------------------------------------------------------------*
 176              	 * Start a thread by invoking its work function.
 177              	 *
 178              	 * Threads execution starts here, the code leaves the system critical zone
 179              	 * and then jumps into the thread function passed in register R4. The
 180              	 * register R5 contains the thread parameter. The function chThdExit() is
 181              	 * called on thread function return.
 182              	 *--------------------------------------------------------------------------*/
 183              	                .thumb_func
 184              	                .globl  __port_thread_start
 185              	__port_thread_start:
 186              	#if CH_DBG_ENABLE_STACK_CHECK && PORT_ENABLE_GUARD_PAGES
 187              	                bl      __port_set_region
 188              	#endif
 189              	#if CH_DBG_SYSTEM_STATE_CHECK
 190              	                bl      __dbg_check_unlock
 191              	#endif
 192              	#if CH_DBG_STATISTICS
 193              	                bl      __stats_stop_measure_crit_thd
 194              	#endif
 195              	#if CORTEX_SIMPLIFIED_PRIORITY
 196              	                cpsie   i
 197              	#else
 198 0018 0023     	                movs    r3, #0              /* CORTEX_BASEPRI_DISABLED */
 199 001a 83F31188 	                msr     BASEPRI, r3
 200              	#endif
 201 001e 2846     	                mov     r0, r5
 202 0020 A047     	                blx     r4
 203 0022 0020     	                movs    r0, #0              /* MSG_OK */
 204 0024 FFF7FEFF 	                bl      chThdExit
 205 0028 FEE7     	.zombies:       b       .zombies
