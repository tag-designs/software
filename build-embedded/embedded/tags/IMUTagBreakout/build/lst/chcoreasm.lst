  73              	/*--------------------------------------------------------------------------*
  74              	 * Performs a context switch between two threads.
  75              	 *--------------------------------------------------------------------------*/
  76              	                .thumb_func
  77              	                .globl  __port_switch
  78              	__port_switch:
  79 0000 2DE9F04F 	                push    {r4, r5, r6, r7, r8, r9, r10, r11, lr}
  80              	#if CORTEX_USE_FPU
  81              	                /* Saving FPU context.*/
  82 0004 2DED108A 	                vpush   {s16-s31}
  83              	#endif
  84              	
  85              	#if PORT_SWITCHED_REGIONS_NUMBER > 0
  86              	                /* Saving MPU context.*/
  87              	                ldr     r2, =MPU_RBAR
  88              	#if PORT_SWITCHED_REGIONS_NUMBER >= 1
  89              	                mov     r3, #0
  90              	                str     r3, [r2, #-4]   /* RNR */
  91              	                ldm     r2, {r4, r5}    /* RBAR, RASR */
  92              	#endif
  93              	#if PORT_SWITCHED_REGIONS_NUMBER >= 2
  94              	                add     r3, #1
  95              	                str     r3, [r2, #-4]   /* RNR */
  96              	                ldm     r2, {r6, r7}    /* RBAR, RASR */
  97              	#endif
  98              	#if PORT_SWITCHED_REGIONS_NUMBER >= 3
  99              	                add     r3, #1
 100              	                str     r3, [r2, #-4]   /* RNR */
 101              	                ldm     r2, {r8, r9}    /* RBAR, RASR */
 102              	#endif
 103              	#if PORT_SWITCHED_REGIONS_NUMBER >= 4
 104              	                add     r3, #1
 105              	                str     r3, [r2, #-4]   /* RNR */
 106              	                ldm     r2, {r10, r11}  /* RBAR, RASR */
 107              	#endif
 108              	#if PORT_SWITCHED_REGIONS_NUMBER == 1
 109              	                push    {r4, r5}
 110              	#endif
 111              	#if PORT_SWITCHED_REGIONS_NUMBER == 2
 112              	                push    {r4, r5, r6, r7}
 113              	#endif
